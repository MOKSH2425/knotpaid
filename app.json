{
  "expo": {
    "name": "KnotPaid",
    "slug": "KnotPaid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/branding/logo.png",
    "scheme": "knotpaid",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "splash": {
      "image": "./src/assets/branding/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1512"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/branding/logo.png",
        "backgroundColor": "#0F1512"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1512",
          "image": "./src/assets/branding/logo.png",
          "imageWidth": 120
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
